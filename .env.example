# Fal.ai
FAL_KEY=
# Optional fallback:
FAL_API_KEY=
# Optional: use this for Fal.ai usage/billing APIs when the normal key is not authorized.
FAL_ADMIN_KEY=
# Optional: broad start date for Fal.ai all-time usage cost lookups.
FAL_USAGE_ALL_TIME_START=2020-01-01

# Auth
NEXTAUTH_SECRET=
NEXTAUTH_URL=https://your-domain.vercel.app
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Database (Vercel Postgres or Supabase)
DATABASE_URL=

# Supabase Storage
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# Paddle Billing
PADDLE_ENVIRONMENT=sandbox
NEXT_PUBLIC_PADDLE_ENVIRONMENT=sandbox
PADDLE_API_KEY=
PADDLE_WEBHOOK_SECRET=
NEXT_PUBLIC_PADDLE_CLIENT_TOKEN=
NEXT_PUBLIC_APP_URL=https://your-domain.vercel.app

# Paddle one-time credit package mappings
PADDLE_PRODUCT_ID_STARTER_CREDITS=
PADDLE_PRICE_ID_STARTER_CREDITS=
PADDLE_PRODUCT_ID_GROWTH_CREDITS=
PADDLE_PRICE_ID_GROWTH_CREDITS=
PADDLE_PRODUCT_ID_AGENCY_CREDITS=
PADDLE_PRICE_ID_AGENCY_CREDITS=
PADDLE_PRODUCT_ID_PRO_CREDITS_25000=
PADDLE_PRICE_ID_PRO_CREDITS_25000=
PADDLE_PRODUCT_ID_PREMIUM_CREDITS_50000=
PADDLE_PRICE_ID_PREMIUM_CREDITS_50000=

# Admin
ADMIN_EMAIL=your-admin@email.com
