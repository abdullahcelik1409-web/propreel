# Fal.ai
FAL_KEY=
# Optional fallback:
FAL_API_KEY=

# Auth
NEXTAUTH_SECRET=
NEXTAUTH_URL=https://your-domain.vercel.app
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Database (Vercel Postgres or Supabase)
DATABASE_URL=

# Supabase Storage
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# Shopier payment links (created after individual account approval)
SHOPIER_STARTER_CREDITS_LINK=
SHOPIER_GROWTH_CREDITS_LINK=
SHOPIER_AGENCY_CREDITS_LINK=
SHOPIER_PRO_CREDITS_25000_URL=
SHOPIER_PREMIUM_CREDITS_50000_URL=

# Shopier REST API (server-side only)
SHOPIER_API_TOKEN=
# Optional fallback name for the same token:
SHOPIER_PAT=

# Shopier webhook automation
SHOPIER_OSB_USERNAME=
SHOPIER_OSB_PASSWORD=
# Optional: used only if Shopier Developer webhook signatures are enabled.
SHOPIER_WEBHOOK_SECRET=
SHOPIER_STARTER_PRODUCT_ID=
SHOPIER_GROWTH_PRODUCT_ID=
SHOPIER_AGENCY_PRODUCT_ID=
SHOPIER_PRO_CREDITS_25000_PRODUCT_ID=
SHOPIER_PREMIUM_CREDITS_50000_PRODUCT_ID=

# Admin
ADMIN_EMAIL=your-admin@email.com
